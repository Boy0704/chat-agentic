# Server
SERVER_PORT=8080
SERVER_API_KEY=your-secret-api-key

# LLM (OpenAI / Ollama / Groq / Azure — OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o

# Database (SQLite — sessions saja, bukan data klien)
DB_PATH=./data/agent.db

# Client API (sistem klien — POS, Ecommerce, dll)
# Skills membaca dari sini untuk akses data bisnis klien
CLIENT_API_BASE_URL=http://localhost:3000
CLIENT_API_AUTH=Bearer xxx

# Custom Skills
CUSTOM_SKILLS_PATH=./custom-skills/

# Logging (LOG_PATH di-set otomatis oleh docker-compose ke /app/logs/agent.log)
# Untuk override level: debug | info | warn | error
LOG_LEVEL=info
